{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "lib": [
            "ES2022"
        ],
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,
        "allowJs": true,
        "strict": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@backend/*": [
                "./packages/backend/*/src/index.ts"
            ],
            "@shared": [
                "./packages/shared/src/index.ts"
            ]
        }
    },
    "files": [],
    "references": [
        {
            "path": "./packages/shared"
        },
        {
            "path": "./packages/backend/db"
        },
        {
            "path": "./packages/backend/analytics"
        },
        {
            "path": "./packages/backend/content-engine"
        },
        {
            "path": "./packages/backend/ai-tutor"
        },
        {
            "path": "./apps/renderer"
        },
        {
            "path": "./apps/desktop"
        }
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build",
        "**/*.config.js",
        "**/*.config.ts"
    ]
}