{
    "name": "desktop",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "description": "Electron main process for Offline Learning App",
    "author": "NavGurukul",
    "main": "./dist/main/index.js",
    "scripts": {
        "dev": "concurrently \"pnpm dev:main\" \"pnpm dev:renderer\"",
        "dev:main": "tsc -b && pnpm copy-preload && electron .",
        "dev:renderer": "pnpm --filter renderer dev",
        "copy-preload": "node -e \"const fs=require('fs'); fs.mkdirSync('dist/preload', { recursive: true }); fs.copyFileSync('src/preload/secure.cjs', 'dist/preload/secure.cjs')\"",
        "build": "tsc && pnpm copy-preload",
        "build:installer": "pnpm build && npx cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config electron-builder.config.cjs",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@afe/shared": "workspace:*",
        "@backend/ai-tutor": "workspace:*",
        "@backend/analytics": "workspace:*",
        "@backend/content-engine": "workspace:*",
        "@backend/db": "workspace:*",
        "@backend/stt-engine": "workspace:*",
        "@backend/tts-engine": "workspace:*",
        "better-sqlite3": "9.6.0",
        "node-record-lpcm16": "^1.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.11.5",
        "concurrently": "^8.2.2",
        "cross-env": "^10.1.0",
        "electron": "^28.1.3",
        "electron-builder": "^24.9.1",
        "prebuild-install": "^7.1.3",
        "typescript": "^5.3.3"
    }
}