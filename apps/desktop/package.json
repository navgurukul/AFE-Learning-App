{
    "name": "desktop",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "description": "Electron main process for Offline Learning App",
    "main": "./dist/main/index.js",
    "scripts": {
        "dev": "concurrently \"pnpm dev:main\" \"pnpm dev:renderer\"",
        "dev:main": "tsc -b && node -e \"require('fs').copyFileSync('src/preload/secure.cjs','dist/preload/secure.cjs')\" && electron .",
        "dev:renderer": "pnpm --filter renderer dev",
        "build": "tsc",
        "build:installer": "pnpm build && electron-builder",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@afe/shared": "workspace:*",
        "@backend/ai-tutor": "workspace:*",
        "@backend/analytics": "workspace:*",
        "@backend/content-engine": "workspace:*",
        "@backend/db": "workspace:*",
        "@backend/stt-engine": "workspace:*",
        "better-sqlite3": "9.6.0",
        "electron": "^28.1.3",
        "node-record-lpcm16": "^1.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.11.5",
        "concurrently": "^8.2.2",
        "electron-builder": "^24.9.1",
        "typescript": "^5.3.3"
    }
}