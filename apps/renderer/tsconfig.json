{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "allowJs": true,
        "isolatedModules": true,
        "paths": {
            "@afe/shared": [
                "../../packages/shared/src/index.ts"
            ]
        }
    },
    "include": [
        "src/**/*"
    ]
}